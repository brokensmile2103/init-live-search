#: init-live-search.php:129
msgid "Show latest posts"
msgstr "Hiển thị bài viết mới nhất"

#: init-live-search.php:133
msgid "Show most viewed posts (all time)"
msgstr "Hiển thị bài viết được xem nhiều nhất (mọi thời điểm)"

#: init-live-search.php:134
msgid "Show trending posts right now"
msgstr "Hiển thị bài viết đang thịnh hành"

#: init-live-search.php:135
msgid "Show most viewed posts today"
msgstr "Hiển thị bài viết được xem nhiều nhất hôm nay"

#: init-live-search.php:136
msgid "Show most viewed posts this week"
msgstr "Hiển thị bài viết được xem nhiều nhất tuần này"

#: init-live-search.php:137
msgid "Show most viewed posts this month"
msgstr "Hiển thị bài viết được xem nhiều nhất tháng này"

#: init-live-search.php:141
msgid "Show posts you recently read (local only)"
msgstr "Hiển thị các bài bạn đã đọc gần đây (chỉ lưu cục bộ)"

#: init-live-search.php:144
msgid "Find posts related to the current page"
msgstr "Tìm các bài viết liên quan đến trang hiện tại"

#: init-live-search.php:145
msgid "Show your favorited posts"
msgstr "Hiển thị bài viết bạn đã đánh dấu yêu thích"

#: init-live-search.php:146
msgid "Clear all favorite posts"
msgstr "Xóa toàn bộ danh sách yêu thích"

#: init-live-search.php:150
msgid "Search all products"
msgstr "Tìm tất cả sản phẩm"

#: init-live-search.php:151
msgid "Show only products on sale"
msgstr "Chỉ hiển thị sản phẩm đang giảm giá"

#: init-live-search.php:152
msgid "Show only in-stock products"
msgstr "Chỉ hiển thị sản phẩm còn hàng"

#: init-live-search.php:153
msgid "Search product by SKU"
msgstr "Tìm sản phẩm theo mã SKU"

#: init-live-search.php:154
msgid "Filter products by brand slug"
msgstr "Lọc sản phẩm theo thương hiệu (slug)"

#: init-live-search.php:155
msgid "Filter products by price range"
msgstr "Lọc sản phẩm theo phạm vi giá"

#: init-live-search.php:156
msgid "Filter products by attribute (e.g. color)"
msgstr "Lọc sản phẩm theo thuộc tính (ví dụ: màu sắc)"

#: init-live-search.php:157
msgid "Filter products by variation value"
msgstr "Lọc sản phẩm theo giá trị biến thể"

#: init-live-search.php:158
msgid "Show all available coupons"
msgstr "Hiển thị tất cả mã giảm giá đang có"

#: init-live-search.php:164
msgid "Open a random post"
msgstr "Mở một bài viết ngẫu nhiên"

#: init-live-search.php:165
msgid "Filter by category"
msgstr "Lọc theo chuyên mục"

#: init-live-search.php:166
msgid "Filter by tag"
msgstr "Lọc theo thẻ"

#: init-live-search.php:167
msgid "Show list of categories"
msgstr "Hiển thị danh sách chuyên mục"

#: init-live-search.php:168
msgid "Show list of tags"
msgstr "Hiển thị danh sách thẻ"

#: init-live-search.php:169
msgid "Filter by date (Y, Y/m, or Y/m/d)"
msgstr "Lọc theo ngày (Y, Y/m hoặc Y/m/d)"

#: init-live-search.php:170
msgid "Go to post by ID"
msgstr "Xem bài viết theo ID"

#: init-live-search.php:171
msgid "Show past search keywords"
msgstr "Hiển thị từ khóa đã tìm trước đó"

#: init-live-search.php:172
msgid "Clear past search keywords"
msgstr "Xóa toàn bộ từ khóa đã tìm trước đó"

#: init-live-search.php:173
msgid "Clear local cache"
msgstr "Xóa cache trình duyệt"

#: init-live-search.php:174
msgid "Reset search field"
msgstr "Đặt lại ô tìm kiếm"

#: init-live-search.php:253
msgid "Type to search..."
msgstr "Nhập để tìm kiếm..."

#: init-live-search.php:254
msgid "No results found."
msgstr "Không tìm thấy kết quả nào."

#: init-live-search.php:255
msgid "Error loading results."
msgstr "Lỗi khi tải kết quả."

#: init-live-search.php:256
msgid "All"
msgstr "Tất cả"

#: init-live-search.php:257
msgid "Cache cleared successfully."
msgstr "Đã xóa cache thành công."

#: init-live-search.php:258
msgid "Favorite list has been cleared."
msgstr "Danh sách yêu thích đã được xóa."

#: init-live-search.php:259
msgid "Failed to clear cache."
msgstr "Không thể xóa cache."

#: init-live-search.php:260
msgid "Quick search"
msgstr "Tìm kiếm nhanh"

#: init-live-search.php:261
msgid "views"
msgstr "lượt xem"

#: init-live-search.php:262
msgid "Sale"
msgstr "Sale"

#: init-live-search.php:263
msgid "Sold out"
msgstr "Hết hàng"

#: init-live-search.php:264
msgid "Supported Commands:"
msgstr "Câu lệnh hỗ trợ:"

#: init-live-search.php:265
msgid "You haven't searched for anything yet."
msgstr "Bạn chưa từng tìm kiếm gì cả."

#: init-live-search.php:266
msgid "Past search keywords have been cleared."
msgstr "Đã xoá toàn bộ lịch sử tìm kiếm."

#: init-live-search.php:281
msgid "Settings"
msgstr "Cài đặt"

#. translators: %s is the discount percentage (e.g. 20 for 20%)
#: includes/rest-api.php:671
#, php-format
msgid "Save %s%%"
msgstr "Giảm %s%%"

#. translators: %s is the monetary discount amount (e.g. $10)
#: includes/rest-api.php:674
#, php-format
msgid "Save %s"
msgstr "Giảm %s"

#. translators: %d is the number of remaining uses
#: includes/rest-api.php:681
#, php-format
msgid "Remaining: %d uses"
msgstr "Còn lại: %d lượt"

#: includes/rest-api.php:683
msgid "Unlimited uses"
msgstr "Không giới hạn lượt"

#. translators: %s is the expiration date
#: includes/rest-api.php:688
#, php-format
msgid "Expires on: %s"
msgstr "Hết hạn: %s"

#: includes/rest-api.php:690
msgid "No expiration"
msgstr "Không giới hạn thời gian"

#: includes/meilisearch.php:144
msgid "Please fill in Host, Index, and Search Key before testing."
msgstr ""
"Vui lòng nhập đầy đủ Host, Index và Search Key trước khi kiểm tra kết nối."

#. translators: %d: HTTP status code
#: includes/meilisearch.php:165
#, php-format
msgid ""
"Meilisearch returned HTTP error %d. Please check your Host / Index / Key."
msgstr ""
"Meilisearch trả về mã lỗi HTTP %d. Vui lòng kiểm tra lại Host / Index / Key."

#. translators: %s is the post title used as fallback alt text
#: includes/utils.php:406
#, php-format
msgid "Image for: %s"
msgstr "Ảnh minh họa cho: %s"

#: includes/settings/general.php:14
msgid "Search Triggers"
msgstr "Cách kích hoạt tìm kiếm"

#: includes/settings/general.php:17
msgid "Post Types to Include"
msgstr "Loại nội dung cần tìm kiếm"

#: includes/settings/general.php:30
msgid "Trigger methods to open modal"
msgstr "Cách để mở giao diện tìm kiếm"

#: includes/settings/general.php:35
msgid "Attach event to input[name=\"s\"]"
msgstr "Gắn sự kiện vào input[name=\"s\"]"

#: includes/settings/general.php:39
msgid "Triple click anywhere on the page"
msgstr "Nhấp chuột 3 lần liên tiếp vào trang"

#: includes/settings/general.php:43
msgid "Press Ctrl + / (or Cmd + / on Mac)"
msgstr "Nhấn Ctrl + / (hoặc Cmd + / trên Mac)"

#: includes/settings/general.php:47
msgid "Select one or more methods to trigger the search modal."
msgstr "Chọn một hoặc nhiều cách để mở hộp tìm kiếm."

#: includes/settings/general.php:52
msgid "Search Behavior"
msgstr "Hành vi tìm kiếm"

#: includes/settings/general.php:55
msgid "Enable Slash Commands?"
msgstr "Bật Slash Command?"

#: includes/settings/general.php:59
msgid "Allow search commands starting with \"/\" such as /recent, /id, /tag, etc."
msgstr ""
"Cho phép sử dụng các lệnh tìm kiếm bắt đầu bằng dấu \"/\" như /recent, /id, "
"/tag, v.v."

#: includes/settings/general.php:64
msgid "Cross-site Search Domains"
msgstr "Tên miền tìm kiếm liên site"

#: includes/settings/general.php:68
msgid "Enter one site per line in the format: Site Name|https://example.com/"
msgstr "Nhập mỗi dòng một site theo định dạng: Tên site|https://example.com/"

#: includes/settings/general.php:69
msgid ""
"When filled, your search will fetch results from these additional domains "
"and merge them into one list."
msgstr ""
"Khi có dữ liệu, hệ thống sẽ lấy kết quả từ các domain này và gộp chung vào "
"một danh sách."

#: includes/settings/general.php:70
msgid ""
"Each external site must also have the Init Live Search plugin installed and "
"active."
msgstr ""
"Mỗi site bên ngoài cũng phải cài và kích hoạt plugin Init Live Search."

#: includes/settings/general.php:75
msgid "Default Slash Command on Modal Open"
msgstr "Slash command mặc định khi mở hộp tìm kiếm"

#: includes/settings/general.php:82
msgid "None (do not preload anything)"
msgstr "Không tải trước gì cả"

#: includes/settings/general.php:83
msgid "Default (/recent)"
msgstr "Mặc định (/recent)"

#: includes/settings/general.php:84
msgid "Related Posts (use /related)"
msgstr "Bài viết liên quan (dùng /related)"

#: includes/settings/general.php:85
msgid "Smart Detection (based on current page)"
msgstr "Tự động nhận diện (theo trang hiện tại)"

#: includes/settings/general.php:89
msgid "Popular Posts (use /popular)"
msgstr "Bài viết phổ biến (dùng /popular)"

#: includes/settings/general.php:90
msgid "Trending Posts (use /trending)"
msgstr "Bài viết xu hướng (dùng /trending)"

#: includes/settings/general.php:94
msgid "Continue Reading (use /read)"
msgstr "Đọc tiếp (dùng /read)"

#: includes/settings/general.php:108
msgid ""
"Choose a default slash command to run automatically when the search modal "
"opens."
msgstr "Chọn slash command mặc định để tự động chạy khi hộp tìm kiếm được mở."

#: includes/settings/general.php:109
msgid ""
"“Smart Detection” automatically detects based on current page: /related for "
"posts, /product for shop pages, taxonomy-based commands, etc."
msgstr ""
"“Tự động nhận diện” sẽ chọn lệnh phù hợp theo trang hiện tại: /related cho "
"bài viết, /product cho trang cửa hàng, hoặc các lệnh dựa trên chuyên mục, "
"thẻ, v.v."

#: includes/settings/general.php:110
msgid ""
"“Popular”, “Trending” and “Read” options are only available if their "
"respective plugins are active."
msgstr ""
"Tuỳ chọn “Popular”, “Trending” và “Read” chỉ hiển thị nếu các plugin tương "
"ứng đang hoạt động."

#: includes/settings/general.php:115
msgid "Only run /related on Single pages?"
msgstr "Chỉ chạy /related trên trang Single?"

#: includes/settings/general.php:119
msgid "Only execute the /related command when viewing a single post page."
msgstr ""
"Chỉ tự động chạy lệnh /related khi đang xem trang bài viết đơn lẻ (single "
"post)."

#: includes/settings/general.php:124
msgid "Exclude /related on pages with these slug keywords"
msgstr "Không chạy /related ở các trang có slug chứa từ khóa sau"

#: includes/settings/general.php:128
msgid ""
"Enter one keyword per line. If the current page slug contains any of these "
"keywords, /related will not auto-run."
msgstr ""
"Nhập mỗi từ khóa một dòng. Nếu slug của trang hiện tại chứa bất kỳ từ khóa "
"này, /related sẽ không tự động chạy."

#: includes/settings/general.php:133
msgid "Use WordPress Native Search?"
msgstr "Dùng tìm kiếm mặc định của WordPress?"

#: includes/settings/general.php:137
msgid ""
"Bypass all custom search logic and use WordPress built-in WP_Query search "
"instead."
msgstr ""
"Bỏ qua toàn bộ logic tìm kiếm tùy chỉnh và dùng WP_Query mặc định của "
"WordPress."

#: includes/settings/general.php:139
msgid ""
"Recommended for small sites or when using third-party search plugins (e.g. "
"SearchWP, ElasticPress) that hook into WP_Query."
msgstr ""
"Khuyến nghị cho site nhỏ hoặc khi dùng plugin tìm kiếm bên thứ ba (ví dụ: "
"SearchWP, ElasticPress) có hook vào WP_Query."

#: includes/settings/general.php:143
msgid "Search Mode"
msgstr "Chế độ tìm kiếm"

#: includes/settings/general.php:148
msgid "Title Only"
msgstr "Chỉ tiêu đề"

#: includes/settings/general.php:152
msgid "Init Smart Tag-Aware Search"
msgstr "Init Smart Tag-Aware Search"

#: includes/settings/general.php:154
msgid ""
"This mode matches against post title and tag names. Ideal for content with "
"rich tagging."
msgstr ""
"Chế độ này sẽ dò theo tiêu đề và tên tag. Thích hợp cho nội dung có gắn tag "
"kỹ lưỡng."

#: includes/settings/general.php:157
msgid "Title and Excerpt"
msgstr "Tiêu đề và trích đoạn"

#: includes/settings/general.php:161
msgid "Title, Excerpt and Content"
msgstr "Tiêu đề, trích đoạn và nội dung"

#: includes/settings/general.php:167
msgid "Enable + / - Search Operators?"
msgstr "Bật toán tử tìm kiếm + / -?"

#: includes/settings/general.php:171
msgid "Allow using +word to force match, -word to exclude."
msgstr "Cho phép dùng +từ để bắt buộc, -từ để loại trừ."

#: includes/settings/general.php:173
msgid ""
"Enable this if you want to support advanced users using must-have (+) and "
"must-not-have (-) keyword operators."
msgstr ""
"Bật tuỳ chọn này nếu bạn muốn hỗ trợ người dùng nâng cao với toán tử bắt "
"buộc (+) và loại trừ (-)."

#: includes/settings/general.php:177
msgid "Show Excerpt in Search Results?"
msgstr "Hiển thị đoạn trích trong kết quả tìm kiếm?"

#: includes/settings/general.php:181
msgid "Display the post excerpt below each result item in the modal."
msgstr "Hiển thị đoạn trích của bài viết bên dưới mỗi kết quả trong modal."

#: includes/settings/general.php:183
msgid "If disabled, excerpt will be omitted from results to simplify the UI."
msgstr ""
"Nếu tắt, đoạn trích sẽ bị loại bỏ khỏi kết quả để làm giao diện gọn hơn."

#: includes/settings/general.php:187
msgid "Use First Image as Thumbnail Fallback?"
msgstr "Sử dụng ảnh đầu tiên làm thumbnail dự phòng?"

#: includes/settings/general.php:196
msgid ""
"Automatically extract the first image from post content when no featured "
"image is available."
msgstr ""
"Tự động lấy ảnh đầu tiên trong nội dung bài viết khi không có ảnh đại diện."

#: includes/settings/general.php:200
msgid ""
"Useful for older posts or sites that do not consistently use featured "
"images."
msgstr ""
"Hữu ích cho các bài viết cũ hoặc website không sử dụng ảnh đại diện một cách"
" đồng nhất."

#: includes/settings/general.php:205
msgid "Search in ACF Fields (Advanced)"
msgstr "Tìm trong trường ACF (Nâng cao)"

#: includes/settings/general.php:208
msgid ""
"Optional. Enter comma-separated ACF field keys to include in search (e.g. "
"company_name, project_code). If left blank, ACF fields will not be searched."
msgstr ""
"Không bắt buộc. Nhập các khóa trường ACF, cách nhau bằng dấu phẩy, để đưa "
"vào tìm kiếm (ví dụ: company_name, project_code). Nếu để trống, plugin sẽ "
"không tìm trong các trường ACF."

#: includes/settings/general.php:212
msgid "Search in SEO Metadata?"
msgstr "Tìm trong metadata SEO?"

#: includes/settings/general.php:216
msgid ""
"Include SEO Title and Meta Description (Yoast, Rank Math, TSF, etc.) in "
"search matching."
msgstr ""
"Tìm kiếm trong tiêu đề SEO và mô tả meta (Yoast, Rank Math, TSF, v.v...) để "
"cải thiện độ chính xác."

#: includes/settings/general.php:218
msgid ""
"Enable this to improve accuracy by searching within SEO-optimized content "
"written by the author."
msgstr ""
"Bật tùy chọn này để cải thiện kết quả bằng cách tìm trong nội dung SEO mà "
"tác giả đã tối ưu."

#: includes/settings/general.php:222
msgid "Enable Synonym Expansion?"
msgstr "Bật chức năng mở rộng từ đồng nghĩa?"

#: includes/settings/general.php:226
msgid ""
"Allow search terms to be expanded using built-in or custom-defined synonyms."
msgstr ""
"Cho phép mở rộng cụm từ tìm kiếm bằng cách sử dụng từ đồng nghĩa có sẵn hoặc"
" do bạn tự định nghĩa."

#: includes/settings/general.php:229
msgid ""
"Enable this only after defining useful synonym mappings. Otherwise, it will "
"have no effect."
msgstr ""
"Chỉ nên bật khi bạn đã khai báo các từ đồng nghĩa phù hợp. Nếu không, tính "
"năng này sẽ không tạo ra hiệu quả."

#: includes/settings/general.php:234
msgid "Enable fallback matching?"
msgstr "Bật khớp dự phòng?"

#: includes/settings/general.php:238
msgid "Try trimming or using bigrams if not enough results are found."
msgstr "Thử rút gọn hoặc sử dụng cụm từ nếu không đủ kết quả."

#: includes/settings/general.php:243
msgid "Enable Search Analytics?"
msgstr "Bật phân tích tìm kiếm?"

#: includes/settings/general.php:247
msgid "Log search queries (term, result count) for analytics purposes."
msgstr ""
"Ghi lại các truy vấn tìm kiếm (từ khóa, số lượng kết quả) để phục vụ phân "
"tích."

#: includes/settings/general.php:249
msgid ""
"When enabled, search data will be stored temporarily using transients to "
"help analyze usage trends. No IPs or personal data are stored."
msgstr ""
"Khi được bật, dữ liệu tìm kiếm sẽ được lưu tạm thời bằng transient để phân "
"tích xu hướng sử dụng. Không lưu địa chỉ IP hoặc dữ liệu cá nhân."

#: includes/settings/general.php:253
msgid "Auto Redirect 404 to Best Match?"
msgstr "Tự động chuyển hướng 404 sang bài viết liên quan nhất?"

#: includes/settings/general.php:262
msgid ""
"When a 404 page is requested, automatically redirect to the most relevant "
"post found by Init Live Search."
msgstr ""
"Khi người dùng vào trang 404, tự động chuyển hướng sang bài viết liên quan "
"nhất được tìm thấy bởi Init Live Search."

#: includes/settings/general.php:265
msgid "Leave unchecked to keep the default 404 behavior of your theme."
msgstr "Bỏ chọn để giữ nguyên hành vi 404 mặc định của giao diện."

#: includes/settings/general.php:270
msgid "Performance & UX"
msgstr "Hiệu năng & Trải nghiệm người dùng"

#: includes/settings/general.php:273
msgid "Debounce Time (ms)"
msgstr "Thời gian chờ tìm kiếm (ms)"

#: includes/settings/general.php:279
msgid "Max Results"
msgstr "Số kết quả tối đa"

#: includes/settings/general.php:282
msgid "Maximum number of results to display in the modal."
msgstr "Số lượng kết quả tối đa hiển thị trong hộp tìm kiếm."

#: includes/settings/general.php:286
msgid "Max Words to Trigger Highlight Search"
msgstr "Số từ tối đa để bật tìm kiếm khi bôi đen"

#: includes/settings/general.php:289
msgid ""
"Set maximum word count allowed to trigger tooltip search on text selection. "
"Set 0 to disable."
msgstr ""
"Thiết lập số từ tối đa được phép để hiển thị tooltip tìm kiếm khi người dùng"
" bôi đen văn bản. Nhập 0 để tắt chức năng này."

#: includes/settings/general.php:293
msgid "Enable Voice Input?"
msgstr "Bật nhập liệu bằng giọng nói?"

#: includes/settings/general.php:297
msgid "Enable microphone input using the SpeechRecognition API (if supported)"
msgstr ""
"Bật nhập liệu bằng micro sử dụng SpeechRecognition API (nếu trình duyệt hỗ "
"trợ)"

#: includes/settings/general.php:302
msgid "Cache results in localStorage?"
msgstr "Lưu kết quả vào localStorage?"

#: includes/settings/general.php:306
msgid ""
"Enable caching search results in localStorage to improve performance and "
"reduce repeated requests."
msgstr ""
"Lưu kết quả tìm kiếm vào localStorage để tăng hiệu suất và giảm yêu cầu lặp "
"lại."

#: includes/settings/general.php:311
msgid "Styling & Suggestions"
msgstr "Giao diện & Gợi ý từ khóa"

#: includes/settings/general.php:314
msgid "Frontend CSS Style"
msgstr "Kiểu giao diện CSS ở giao diện người dùng"

#: includes/settings/general.php:319
msgid "Default (modal-style)"
msgstr "Mặc định (kiểu modal)"

#: includes/settings/general.php:323
msgid "Full Screen Overlay"
